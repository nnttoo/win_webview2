{
  "name": "win_webview2",
  "version": "1.1.16",
  "repository": {
    "type": "git",
    "url": "https://github.com/nnttoo/win_webview2"
  },
  "description": "",
  "main": "./tsDist/tsExport/winwebview2.js",
  "types": "./tsDist/tsExport/winwebview2.d.ts",
  "exports": {
    "./browser": {
      "types": "./dist/browser/ww2_browser.d.ts",
      "default": "./dist/browser/ww2_browser.js"
    },
    "./node": {
      "types": "./dist/node/tsExport/winwebview2.dt.ts",
      "default": "./dist/node/tsExport/winwebview2.js"
    }
  },
  "bin": {
    "win_webview2": "tsDistRun.js",
    "wwv": "tsDistRun.js"
  },
  "type": "commonjs",
  "scripts": {
    "build_node": "tsc -p ./src/srcNode/tsconfig.json",
    "build_node_watch": "npm run build_node -- --watch",
    "build_browser": "tsc -p ./src/srcBrowser/tsconfig.json",
    "build_browser_watch": "npm run build_browser -- --watch",
    "build_all" : "npm run build_node && npm run build_browser",
    "copy_dll": "tsx ./srcInternal/copyDll.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "comment-json": "^4.6.2",
    "degit": "^2.8.4",
    "express": "^5.2.1",
    "prompts": "^2.4.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/prompts": "^2.4.9",
    "typescript": "^6.0.2"
  }
}
